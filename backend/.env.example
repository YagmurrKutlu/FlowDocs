NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

DATABASE_URL=postgresql://flowdocs:flowdocs@localhost:5432/flowdocs?schema=public
DOCUMENT_SNAPSHOT_INTERVAL=3

JWT_SECRET=replace-with-a-strong-secret-key
JWT_EXPIRES_IN=1h

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=flowdocs
MINIO_SECRET_KEY=flowdocs-secret
MINIO_BUCKET=flowdocs-media
